{
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "framework": "vite",
  "functions": {
    "api/analyze.ts": { "maxDuration": 60 },
    "api/analyze-batch.ts": { "maxDuration": 60 },
    "api/health.ts": { "maxDuration": 5 }
  },
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api/$1" },
    { "source": "/(.*)", "destination": "/index.html" }
  ]
}

# =====================================
# 서버 측 (Vercel 함수 환경변수) — 클라이언트 번들에 절대 들어가지 않음
# Vercel Dashboard > Project > Settings > Environment Variables 에 등록할 것.
# =====================================
GEMINI_API_KEY="..."
ANTHROPIC_API_KEY="..."
GROQ_API_KEY="..."

# =====================================
# 클라이언트 노출 변수 (VITE_ prefix) — 번들에 포함됨
# Supabase anon 키는 공개 키라 노출 OK.
# =====================================
VITE_SUPABASE_URL="https://xxx.supabase.co"
VITE_SUPABASE_ANON_KEY="eyJ..."

# 모바일 빌드용 API base (절대 URL). 웹은 .env.production 의 빈 값 사용.
# VITE_API_BASE=https://good-diet.vercel.app

# =====================================
# Capacitor (모바일 dev)
# =====================================
CAPACITOR_SERVER_URL=http://192.168.0.x:3000
